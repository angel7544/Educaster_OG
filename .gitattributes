# Auto detect text files and perform LF normalization
* text=auto

# Custom for Windows
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Maintain LF for code and config to be safe across OS
*.java text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.css text eol=lf
*.html text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.sql text eol=lf
*.properties text eol=lf
*.py text eol=lf
